# Скопируйте в .env и заполните значения локально. Секреты не коммитить.
# Имена ниже — канон проекта. Скрипт `backend/check_config.py` принимает и алиасы (см. блок ниже и README).

# --- Алиасы (поддерживаются; достаточно задать канон ИЛИ один из алиасов на роль) ---
# RETAILCRM_API_KEY  ←  API_RETAIL_TOKEN
# RETAILCRM_API_URL  ←  API_RETAIL_URL_METHODS (часто вставляют URL документации; для API нужен базовый URL аккаунта, см. README)
# SUPABASE_URL  ←  NEXT_PUBLIC_SUPABASE_URL, VITE_SUPABASE_URL
# SUPABASE_ANON_KEY  ←  NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, VITE_SUPABASE_ANON_KEY
# VITE_SUPABASE_URL  ←  SUPABASE_URL, NEXT_PUBLIC_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY  ←  SUPABASE_ANON_KEY, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# TELEGRAM_BOT_TOKEN  ←  API_TELEGRAM_TOKEN
# TELEGRAM_CHAT_ID  ←  TELEGRAM_NAME (только числовой id или @канал; не «имя» человека)

# --- RetailCRM (REST API v5) ---
# RETAILCRM_API_URL — базовый URL аккаунта, например https://<поддомен>.retailcrm.ru
#   (без суффикса /api/v5 — его добавляет клиент при вызовах).
# RETAILCRM_API_KEY — ключ из раздела интеграций / API в админке демо-аккаунта.
# RETAILCRM_SITE — символьный код магазина (если reference/sites пуст или нужен конкретный магазин):
#   админка → Настройки → Магазины → поле «Код».
RETAILCRM_API_URL=
RETAILCRM_API_KEY=
RETAILCRM_SITE=
# Символьные коды из справочников CRM (если коды в mock_orders.json не совпадают с вашим аккаунтом):
# RETAILCRM_ORDER_TYPE_CODE=
# RETAILCRM_ORDER_METHOD_CODE=

# --- Supabase (Python / сервер: anon при необходимости; service_role — только бэкенд, не в браузер) ---
# SUPABASE_URL — URL проекта (Project URL в настройках).
# SUPABASE_ANON_KEY — публичный anon key (для RLS-совместимых сценариев из скриптов при необходимости).
# SUPABASE_SERVICE_ROLE_KEY — опционально до сценариев записи из Python; для записи в БД из бэкенда обязателен (не во фронт).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram ---
# TELEGRAM_BOT_TOKEN — токен от @BotFather.
# TELEGRAM_CHAT_ID — id ПОЛУЧАТЕЛЯ (ваш user id или группы), НЕ id бота. На скрине @userinfobot: «Id: 611…» у вас — это вы; если ответ «Id: 86…» после пересланного сообщения от бота — это id бота, в .env так не ставить. Личка: /start вашему боту, в .env ваш числовой user id.
# ALERT_MIN_AMOUNT_KZT — порог суммы для backend (telegram_watch_orders и др.; см. backend/alert_env.py).
# ALERT_CURRENCY_CODES — допустимые коды валюты через запятую (по умолчанию KZT,398,RUB,643; для только ₸ задайте KZT,398).
# TELEGRAM_ORDER_ID_PROBE — сколько id подряд после watermark опрашивать GET orders/{id} (0-200, по умолчанию 40).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_MIN_AMOUNT_KZT=50000
# ALERT_CURRENCY_CODES=KZT,398,RUB,643
# TELEGRAM_ORDER_ID_PROBE=40

# --- Vite (frontend/: только публичные данные; service_role сюда не класть) ---
# Дублируют Supabase URL и anon для сборки Vite (import.meta.env.VITE_*).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
